NEON_DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"
OPENAI_API_KEY="sk-..."
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS=1536
MISTRAL_CLIENT_API_KEY="..."
MODEL_NAME="pixtral-12b-latest"

# BM25 & Local Reranker Config (RAG Enhancement)
BM25_INDEX_PATH="data/processed_data/bm25_index.pkl"
RERANKER_ENABLED=true
RERANKER_MODEL="cross-encoder/ms-marco-MiniLM-L-6-v2"
RERANKER_MAX_CANDIDATES=12
